rolling_dice <- function(){
die <- 1:6
roll <- sample(die, 2, FALSE)
sum <- sum(roll)
cat("The die rolled to", paste(roll, collapse = ", "), "and the sum of the rolls is", paste(sum))
}
rolling_dice()
rolling_dice <- function(){
die <- 1:6
roll <- sample(die, 10, FALSE)
sum <- sum(roll)
cat("The die rolled to", paste(roll, collapse = ", "), "and the sum of the rolls is", paste(sum))
}
rolling_dice()
rolling_dice <- function(){
die <- 1:6
roll <- sample(die, 10, TRUE)
sum <- sum(roll)
cat("The die rolled to", paste(roll, collapse = ", "), "and the sum of the rolls is", paste(sum))
}
rolling_dice()
